rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Blog thumbnail uploads - allow public write with validation
    match /blog-thumbnails/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Blog inline images (from RichTextEditor)
    match /blog-images/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
