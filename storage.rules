rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Blog thumbnail uploads - allow public write with validation
    match /blog-thumbnails/{fileName} {
      allow read: if true;
      allow create, update: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if true;
    }

    // Blog inline images (from RichTextEditor)
    match /blog-images/{fileName} {
      allow read: if true;
      allow create, update: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if true;
    }

    // Pet profile images
    match /pet-images/{fileName} {
      allow read: if true;
      allow create, update: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if true;
    }

    // User avatar uploads
    match /avatars/{fileName} {
      allow read: if true;
      allow create, update: if request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if true;
    }
  }
}
